{
  "name": "simple-custom-question",
  "version": "1.0.0",
  "private": true,
  "description": "Learnosity custom question demo (Vite + Express)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently -k -n server,client -c blue,green \"npm:start:server\" \"npm:start:client\"",
    "dev": "concurrently -k -n server,client -c blue,green \"npm:start:server\" \"npm:start:client\"",
    "build": "npm run build --workspace client",
    "preview": "npm run preview --workspace client",
    "start:server": "npm start --workspace server",
    "start:client": "npm run dev --workspace client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christian-crisologo-lrn/simple-custom-question.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/christian-crisologo-lrn/simple-custom-question"
  },
  "homepage": "https://github.com/christian-crisologo-lrn/simple-custom-question#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
